# Data Source API Keys
export CMC_API_KEY="your_cmc_api_key_here"
export COINGECKO_API_KEY="your_coingecko_api_key_here"
export BINANCE_API_KEY="your_binance_api_key_here"

# Google Sheets Output (optional)
export GOOGLE_SHEET_ID="your_google_sheet_id_here"
export GOOGLE_SERVICE_ACCOUNT_KEY="./config/gsa.json"

# Airtable Output (optional)
export AIRTABLE_BASE_ID="your_airtable_base_id_here"
export AIRTABLE_API_KEY="your_airtable_api_key_here"

# SMTP Email Configuration
export SMTP_HOST="smtp.example.com"
export SMTP_PORT=587
export SMTP_USER="your_smtp_username"
export SMTP_PASSWORD="your_smtp_password"
export SMTP_FROM="partnerships@example.com"

# Channel BD Settings
export CHANNEL_BD_LOG_LEVEL="info"
export CHANNEL_BD_DRY_RUN="true"
export CHANNEL_BD_CONFIG_PATH="./config/channel-bd.json"
